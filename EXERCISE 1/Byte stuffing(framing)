#include <stdio.h>
#include <string.h>

void printBinary(char ch)
{
    int i;
    for(i = 7; i >= 0; i--)
        printf("%d", (ch >> i) & 1);
}

int main()
{
    char data[100];
    char stuffed[200];
    char destuffed[100];
    int i, j = 0;

    printf("Enter text: ");
    scanf("%s", data);

    printf("\nOriginal Data in Binary:\n");
    for(i = 0; data[i] != '\0'; i++)
    {
        printBinary(data[i]);
        printf(" ");
    }

    stuffed[j++] = 'F';

    for(i = 0; data[i] != '\0'; i++)
    {
        if(data[i] == 'F')
        {
            stuffed[j++] = 'E';
            stuffed[j++] = 'F';
        }
        else if(data[i] == 'E')
        {
            stuffed[j++] = 'E';
            stuffed[j++] = 'E';
        }
        else
        {
            stuffed[j++] = data[i];
        }
    }

    stuffed[j++] = 'F';
    stuffed[j] = '\0';

    printf("\n\nByte Stuffed Frame:\n%s", stuffed);

    printf("\n\nByte Stuffed Frame in Binary:\n");
    for(i = 0; stuffed[i] != '\0'; i++)
    {
        printBinary(stuffed[i]);
        printf(" ");
    }

    int len = strlen(stuffed);
    int start = 1;
    int end = len - 1;
    j = 0;

    for(i = start; i < end; i++)
    {
        if(stuffed[i] == 'E')
        {
            destuffed[j++] = stuffed[i+1];
            i++;
        }
        else
        {
            destuffed[j++] = stuffed[i];
        }
    }
    destuffed[j] = '\0';

    printf("\n\nByte Destuffed Data:\n%s", destuffed);

    printf("\n\nByte Destuffed Data in Binary:\n");
    for(i = 0; destuffed[i] != '\0'; i++)
    {
        printBinary(destuffed[i]);
        printf(" ");
    }

    printf("\n");
    return 0;
}
