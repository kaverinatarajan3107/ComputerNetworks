//Given a positive integer, check whether it has alternating bits: namely, if two adjacent bits will always have different values.
bool hasAlternatingBits(int n) {
    int temp = n;
    int binarray[32];
    int bitcount=0;
    if(n==0){
        binarray[0]=0;
        bitcount++;
    }
    else{
        while(temp>0){
            binarray[bitcount]=temp&1;
            bitcount++;
            temp=temp>>1;
        }
        int start=0;
        int end=bitcount-1;
        while(start<end){
            int temp=binarray[start];
            binarray[start]=binarray[end];
            binarray[end]=temp;
            start++;
            end--;
        }
    } 
    int i;
    for(i=0;i<bitcount-1;i++)
    {
        if(binarray[i] == binarray[i+1]){
            return FALSE;
        }
        else{
            continue;
        }
    }   
    return TRUE;
}
