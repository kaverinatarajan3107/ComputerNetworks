#include <stdio.h>

void calculate_the_maximum(int n, int k) {
    int max_and = 0;
    int max_or = 0;
    int max_xor = 0;
    int i, j;

    // Compare all pairs (i, j) such that 1 <= i < j <= n
    for (i = 1; i <= n; i++) {
        for (j = i + 1; j <= n; j++) {
            int current_and = i & j;
            int current_or  = i | j;
            int current_xor = i ^ j;

            // Check if current AND value is less than k and greater than previous max
            if (current_and < k && current_and > max_and) {
                max_and = current_and;
            }

            // Check if current OR value is less than k and greater than previous max
            if (current_or < k && current_or > max_or) {
                max_or = current_or;
            }

            // Check if current XOR value is less than k and greater than previous max
            if (current_xor < k && current_xor > max_xor) {
                max_xor = current_xor;
            }
        }
    }

    // Print results as required by the challenge
    printf("%d\n", max_and);
    printf("%d\n", max_or);
    printf("%d\n", max_xor);
}

int main() {
    int n, k;
    
    // Read input values for n and k
    if (scanf("%d %d", &n, &k) == 2) {
        calculate_the_maximum(n, k);
    }
    
    return 0;
}
