#include <stdio.h>
#include <string.h>

int main()
{
    char text[100];
    char binary[1000] = "";
    char stuffed[1200] = "";
    char flag[] = "01111110";
    int i, j, count;

    printf("Enter text: ");
    scanf("%s", text);

    for (i = 0; text[i] != '\0'; i++)
    {
        for (j = 7; j >= 0; j--)
        {
            if ((text[i] >> j) & 1)
                strcat(binary, "1");
            else
                strcat(binary, "0");
        }
    }

    printf("\nBinary Data : %s\n", binary);

    count = 0;
    j = 0;

    for (i = 0; binary[i] != '\0'; i++)
    {
        stuffed[j++] = binary[i];

        if (binary[i] == '1')
            count++;
        else
            count = 0;

        if (count == 5)
        {
            stuffed[j++] = '0';
            count = 0;
        }
    }

    stuffed[j] = '\0';

    printf("Bit Stuffed Data : %s\n", stuffed);

    char frame[2000] = "";
    strcat(frame, flag);
    strcat(frame, stuffed);
    strcat(frame, flag);

    printf("\nFinal Frame:\n");
    printf("%s\n", frame);

    char destuffed[1000] = "";
    int frame_len = strlen(frame);
    int data_start = 8;
    int data_end = frame_len - 8;

    count = 0;
    j = 0;

    for (i = data_start; i < data_end; i++)
    {
        destuffed[j++] = frame[i];

        if (frame[i] == '1')
            count++;
        else
            count = 0;

        if (count == 5)
        {
            i++;
            count = 0;
        }
    }
    destuffed[j] = '\0';

    printf("\nDestuffed Binary Data: %s\n", destuffed);

    return 0;
}
